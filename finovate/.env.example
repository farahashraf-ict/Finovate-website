# Finovate website (Vite dev server) -> SDK reverse proxy target
# Used only by the Vite dev server proxy in vite.config.ts
SDK_PROXY_TARGET=http://localhost:9876

# SDK secrets (DO NOT expose in browser code)
# These are read by the Vite dev server (Node) to inject headers to the SDK.
# In production, inject these headers in your reverse proxy (e.g., Nginx), not in the SPA.
SDK_API_KEY=REPLACE_WITH_SDK_API_KEY
SDK_PLAYGROUND_SECRET=REPLACE_WITH_SDK_PLAYGROUND_SECRET
